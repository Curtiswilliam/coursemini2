# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://coursemini:YOUR_DB_PASSWORD@localhost/coursemini

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=replace_with_long_random_string

# Used to promote first admin via POST /api/auth/promote-admin
ADMIN_SECRET=replace_with_secret_token

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ─── Email (optional — for real email sending) ────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=noreply@yourdomain.com
